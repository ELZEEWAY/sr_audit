{
  "name": "sr-audit-system",
  "version": "1.0.0",
  "description": "STANDALONE ELECTRON DESKTOP SHELL FOR DILG SANTA ROSA BARANGAY AUDIT SYSTEM",
  "main": "main.js",
  "scripts": {
    "build": "echo 'Skipping Electron build'",
    "start": "node server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.1",
    "pg": "^8.11.3",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.dilg.srauditsystem",
    "productName": "SRAuditSystem",
    "win": {
      "target": [
        "portable"
      ]
    },
    "directories": {
      "output": "../build-dist-out"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "pages/**/*",
      "javascript/**/*",
      "style/**/*",
      "Assets/**/*",
      "lib/**/*",
      ".env"
    ]
  }
}